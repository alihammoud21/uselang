# Core app routing
VITE_MAIN_APP_ORIGIN=http://localhost:3001
VITE_API_BASE_URL=http://127.0.0.1:8788
VITE_APP_STORE_URL=

# Private local usage dashboard
USAGE_DASHBOARD_PASSWORD=change-me

# Optional backend provider selection
STT_PROVIDER=deepgram
TTS_PROVIDER=deepgram
OCR_PROVIDER=tesseract
STORAGE_PROVIDER=s3

# Optional speech-to-text providers
DEEPGRAM_API_KEY=
DEEPGRAM_STT_API_KEY=

# Optional text-to-speech providers
DEEPGRAM_TTS_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Firebase Auth / server-side admin scaffolding
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Storage provider
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=

# Local API / tutor sidecars
API_HOST=127.0.0.1
API_PORT=8788
LESSON_SERVICE_URL=http://127.0.0.1:8787

# Dev bypass — skips Firebase auth on tutor-session and stt endpoints.
# NEVER enable in production.
LANG_DEV_MODE=0

# ─────────────────────────────────────────────────────────────────────────────
# Mobile app (expo) — these go in apps/uselang-app/.env and must be prefixed
# with EXPO_PUBLIC_ so they get embedded at build time.
# ─────────────────────────────────────────────────────────────────────────────
#
# For the iOS Simulator, 127.0.0.1 resolves to the Mac's loopback and WILL
# reach netlify dev on the same host. For a physical device on the same
# Wi-Fi, replace with your Mac's LAN IP (find via `ipconfig getifaddr en0`).
#
#   EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8788
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8788  # LAN IP example
#
# Do NOT put LLM API keys here. The mobile app never calls a cloud LLM.
# Core text generation always runs through local on-device Gemma.
# Optional cloud STT/TTS can use backend keys above but must not be required.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8788

# Local Gemma sources for react-native-executorch. These must point to
# bundled/local file:// resources, not http(s) URLs.
EXPO_PUBLIC_GEMMA_MODEL_SOURCE=
EXPO_PUBLIC_GEMMA_TOKENIZER_SOURCE=
EXPO_PUBLIC_GEMMA_TOKENIZER_CONFIG_SOURCE=
