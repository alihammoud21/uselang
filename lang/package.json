{
  "name": "langora",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lesson:dev": "node services/lesson-generator/server.js",
    "dev": "vite --config vite.config.js",
    "dev:full": "sh -c 'npm run lesson:dev & npm run dev'",
    "build": "vite build --config vite.config.js && node scripts/write-redirects.mjs",
    "preview:netlify": "npm run build && vite preview --config vite.config.js --host 0.0.0.0 --port 4173",
    "preview": "vite preview --config vite.config.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "framer-motion": "^12.9.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.4",
    "vite": "^8.0.4"
  }
}
