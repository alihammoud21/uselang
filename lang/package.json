{
  "name": "langora",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api:dev": "node --env-file=.env server/api-server.js",
    "lesson:dev": "node services/lesson-generator/server.js",
    "dev": "vite --config vite.config.js",
    "dashboard:dev": "vite --config vite.usage-dashboard.config.js",
    "dashboard:build": "vite build --config vite.usage-dashboard.config.js",
    "dev:full": "sh -c 'npm run api:dev & npm run lesson:dev & npm run dev'",
    "build": "vite build --config vite.config.js && node scripts/write-redirects.mjs",
    "preview:netlify": "npm run build && vite preview --config vite.config.js --host 0.0.0.0 --port 4173",
    "preview": "vite preview --config vite.config.js",
    "video:studio": "remotion studio remotion/index.ts",
    "video:render:appstore": "remotion render remotion/index.ts LangAppPreview69 out/lang-app-preview-886x1920.mp4",
    "lint": "eslint .",
    "netlify:dev": "npx netlify dev",
    "mobile:dev": "npm --prefix apps/uselang-app run start",
    "mobile:ios": "npm --prefix apps/uselang-app run ios",
    "mobile:android": "npm --prefix apps/uselang-app run android",
    "tutor:dev": "sh -c 'npm run api:dev & sleep 2 && npm run mobile:dev'"
  },
  "dependencies": {
    "express": "^5.2.1",
    "fdir": "^6.5.0",
    "firebase": "^12.12.0",
    "framer-motion": "^12.9.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.448",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@remotion/cli": "^4.0.448",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.4",
    "vite": "^8.0.8"
  }
}
