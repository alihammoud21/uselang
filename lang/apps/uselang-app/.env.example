# ── Lang Expo client ─────────────────────────────────────────────────────────
# The mobile app is deliberately key-free: all cloud providers are called
# server-side. The only thing you set here is the tutor API base URL.

# Base URL for the tutor backend. For local dev on a simulator use 127.0.0.1;
# for a physical device on the same Wi-Fi use your LAN IP (e.g. 192.168.1.42).
# In production set this to your deployed Netlify URL.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8788
