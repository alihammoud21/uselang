{
  "name": "speechcode",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "PATH=\"$PWD/scripts:$PATH\" turbo run build",
    "dev": "PATH=\"$PWD/scripts:$PATH\" turbo run dev --parallel --filter=@speechcode/desktop --filter=@speechcode/website",
    "start": "corepack pnpm dev",
    "dev:desktop": "corepack pnpm --filter @speechcode/desktop dev",
    "dev:website": "corepack pnpm --filter @speechcode/website dev",
    "package:desktop": "corepack pnpm --filter @speechcode/desktop package"
  },
  "devDependencies": {
    "turbo": "^2.0.12",
    "typescript": "^5.5.4"
  }
}
